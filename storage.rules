rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Evidence files for PCN appeals
    match /{pcnRef}/{allPaths=**} {
      // Allow upload for authenticated users (via appeal form)
      // Files are stored under the PCN reference number
      allow create: if request.resource.size < 5 * 1024 * 1024  // Max 5MB
                   && request.resource.contentType.matches('image/jpeg|image/png|application/pdf');
      
      // Allow read for the appeal owner and council
      allow read: if true;  // Public read for PDF generation
      
      // No updates or deletes from client
      allow update, delete: if false;
    }
  }
}