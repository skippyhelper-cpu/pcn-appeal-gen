rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.firebase.sign_in_provider == 'gcip_cloud_event' ||
         request.auth.token.email == 'firebase-adminsdk@example.com');
    }
    
    function isValidAppealCreate() {
      let data = request.resource.data;
      return data.keys().hasAll(['pcnRef', 'email', 'vehicleReg', 'createdAt'])
        && data.pcnRef is string && data.pcnRef.size() > 0
        && data.email is string && data.email.matches('^[^@]+@[^@]+\\.[^@]+')
        && data.vehicleReg is string && data.vehicleReg.size() > 0
        && data.createdAt is timestamp;
    }

    match /appeals/{appealId} {
      // Anyone can create an appeal (initial submission before payment)
      allow create: if isValidAppealCreate();
      
      // Allow reading own appeal via Cloud Function after payment
      // The getAppeal Cloud Function checks payment status server-side
      allow read: if true;
      
      // No direct updates or deletes from client - managed via Cloud Functions
      allow update, delete: if false;
      
      // No direct updates or deletes from client - managed via Cloud Functions
      allow update, delete: if false;
    }
    
    match /payments/{paymentId} {
      // Payments are written by Cloud Functions (Stripe webhooks) with admin SDK
      // Admin SDK bypasses rules, so this just needs to block client access
      allow read, write: if false;
    }
    
    match /feedback/{feedbackId} {
      // Anyone can submit feedback
      allow create: if request.resource.data.keys().hasAll(['message', 'createdAt']) 
                    && request.resource.data.message is string
                    && request.resource.data.message.size() > 0
                    && request.resource.data.message.size() < 5000;
      
      // Only admin can read feedback
      allow read: if isAdmin();
      
      // No updates or deletes from client
      allow update, delete: if false;
    }
    
    match /mail/{mailId} {
      // Mail collection used by Firebase Extensions - admin only
      allow read, write: if false;
    }
  }
}